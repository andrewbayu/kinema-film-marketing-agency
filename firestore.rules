rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------
    // Global Deny
    // -------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------
    // Primitives & Helpers
    // -------------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email_verified == true && (
          request.auth.token.email == 'andrew.bayu23@gmail.com' || 
          exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
          exists(/databases/$(database)/documents/team/$(request.auth.token.email))
        )
      );
    }

    function isCampaignOwner(campaignId) {
      return isAdmin() || (
        isSignedIn() && 
        exists(/databases/$(database)/documents/campaigns/$(campaignId)) &&
        get(/databases/$(database)/documents/campaigns/$(campaignId)).data.userId == request.auth.uid
      );
    }

    // -------------------------------------------------------------
    // Validation Blueprints
    // -------------------------------------------------------------
    
    function isValidCampaign(data) {
      return (data.userId == request.auth.uid || isAdmin())
          && data.title is string && data.title.size() <= 200
          && data.createdAt is timestamp
          && (data.get('lastVisibilityScan', null) == null || data.lastVisibilityScan is timestamp)
          && (data.get('releaseDate', null) == null || (data.releaseDate is string && data.releaseDate.size() <= 64));
    }

    function isValidVisibility(data) {
      return (data.userId == request.auth.uid || isAdmin())
          && data.campaignId is string && data.campaignId.size() <= 128
          && data.visibilityScore is number
          && data.sentiment is map
          && (data.get('metrics', null) == null || data.metrics is map)
          && (data.get('trajectory', null) == null || data.trajectory is map)
          && (data.get('funnel', null) == null || data.funnel is map)
          && (data.get('platformPerformance', null) == null || data.platformPerformance is list)
          && (data.get('evidencePoints', null) == null || data.evidencePoints is list)
          && (data.get('trends', null) == null || data.trends is list)
          && (data.get('topGeographies', null) == null || data.topGeographies is list)
          && (data.get('summary', null) == null || data.summary is string)
          && (data.get('strategicAdvice', null) == null || data.strategicAdvice is string)
          && (data.get('benchmarkContext', null) == null || data.benchmarkContext is string)
          && data.createdAt is timestamp;
    }

    // -------------------------------------------------------------
    // Match Blocks
    // -------------------------------------------------------------
    
    match /team/{email} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /clients/{clientId} {
      allow read: if isSignedIn() && (resource.data.email == request.auth.token.email || isAdmin());
      allow write: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn() && (request.auth.uid == adminId || isAdmin());
      allow write: if isAdmin();
    }

    match /campaigns/{campaignId} {
      allow read: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isSignedIn() && isValidCampaign(incoming()) && incoming().createdAt == request.time;
      allow update: if (isOwner(resource.data.userId) || isAdmin()) && (
        // Action: Generic Profile Update
        (isValidCampaign(incoming()) && 
         incoming().userId == resource.data.userId && 
         incoming().createdAt == resource.data.createdAt &&
         incoming().diff(resource.data).affectedKeys().hasOnly(['title', 'genre', 'budgetTier', 'releaseWindow', 'releaseDate', 'logline', 'leadCast', 'ipType', 'director', 'status'])) ||
        // Action: Update Scan Timestamp
        (incoming().diff(resource.data).affectedKeys().hasOnly(['lastVisibilityScan']) && incoming().lastVisibilityScan == request.time)
      );
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /visibility_tracker/{scanId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() 
                     && isValidVisibility(incoming())
                     && (isAdmin() || isCampaignOwner(incoming().campaignId))
                     && (incoming().createdAt == request.time || (isAdmin() && incoming().createdAt <= request.time));
      allow update: if false; 
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /audience_dna/{dnaId} {
      allow read: if isOwner(existing().userId) || isAdmin();
      allow create: if isSignedIn() && isCampaignOwner(incoming().campaignId);
      allow delete: if isOwner(existing().userId) || isAdmin();
    }

    match /box_predict/{predictId} {
      allow read: if isOwner(existing().userId) || isAdmin();
      allow create: if isSignedIn() && isCampaignOwner(incoming().campaignId);
      allow delete: if isOwner(existing().userId) || isAdmin();
    }

    match /fib/{fibId} {
      allow read: if isOwner(existing().userId) || isAdmin();
      allow create: if isSignedIn() && isCampaignOwner(incoming().campaignId);
      allow delete: if isOwner(existing().userId) || isAdmin();
    }

    match /cineforge/{forgeId} {
      allow read: if isOwner(existing().userId) || isAdmin();
      allow create: if isSignedIn() && isCampaignOwner(incoming().campaignId);
      allow delete: if isOwner(existing().userId) || isAdmin();
    }
  }
}
