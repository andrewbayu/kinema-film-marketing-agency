rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------
    // Global Deny
    // -------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------
    // Primitives
    // -------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email_verified == true && (
          request.auth.token.email == 'andrew.bayu23@gmail.com' || 
          exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
          exists(/databases/$(database)/documents/team/$(request.auth.token.email))
        )
      );
    }

    function belongsToOwnCampaign(campaignId) {
      return isAdmin() || (
        isSignedIn() && (
          campaignId == null || campaignId == "" || campaignId == "new" ||
          !exists(/databases/$(database)/documents/campaigns/$(campaignId)) || 
          get(/databases/$(database)/documents/campaigns/$(campaignId)).data.userId == request.auth.uid
        )
      );
    }

    // -------------------------------------------------------------
    // Entities
    // -------------------------------------------------------------
    
    // Team Management (Internal Admins)
    match /team/{email} {
      function isValidTeamMember(data) {
        return data.email == email && data.email.size() <= 100
            && data.role in ['admin', 'super_admin']
            && data.addedBy == request.auth.uid
            && data.createdAt is timestamp;
      }
      allow read: if isSignedIn();
      allow create, update: if isAdmin() && isValidTeamMember(incoming()) && incoming().createdAt == request.time;
      allow delete: if isAdmin();
    }

    // Clients Authorization
    match /clients/{clientId} {
      function isValidClient(data) {
        return data.email is string && data.email.size() <= 100
            && data.addedBy == request.auth.uid
            && data.createdAt is timestamp;
      }
      allow read: if isSignedIn() && (resource.data.email == request.auth.token.email || isAdmin());
      allow create: if isAdmin() && isValidId(clientId) && isValidClient(incoming())
                     && incoming().createdAt == request.time;
      allow delete: if isAdmin();
    }

    // Admins
    match /admins/{adminId} {
      allow read: if isSignedIn() && (request.auth.uid == adminId || isAdmin());
      allow write: if isAdmin();
    }

    // Campaigns
    match /campaigns/{campaignId} {
      function isValidCampaign(data) {
        return (data.userId == request.auth.uid || isAdmin())
            && data.title is string && data.title.size() <= 200
            && data.createdAt is timestamp;
      }

      allow read: if isOwner(existing().userId) || isAdmin();
      allow create: if isSignedIn() && isValidId(campaignId) && isValidCampaign(incoming()) 
                     && incoming().createdAt == request.time;
      allow update: if (isOwner(existing().userId) || isAdmin()) && isValidCampaign(incoming())
                     && (isAdmin() || (incoming().userId == existing().userId && incoming().createdAt == existing().createdAt));
      allow delete: if isOwner(existing().userId) || isAdmin();
    }

    // Audience DNA
    match /audience_dna/{dnaId} {
      function isValidDNA(data) {
        return (data.userId == request.auth.uid || isAdmin())
            && (data.campaignId is string || data.campaignId == null)
            && (data.results is map || data.results is string)
            && data.createdAt is timestamp;
      }

      allow read: if isOwner(existing().userId) || isAdmin();
      allow create: if isSignedIn() && isValidDNA(incoming())
                     && belongsToOwnCampaign(incoming().campaignId);
      allow update: if false; 
      allow delete: if isOwner(existing().userId) || isAdmin();
    }

    // Box Predict
    match /box_predict/{predictId} {
      function isValidPredict(data) {
        return (data.userId == request.auth.uid || isAdmin())
            && (data.campaignId is string || data.campaignId == null)
            && (data.results is map || data.results is string)
            && data.createdAt is timestamp;
      }

      allow read: if isOwner(existing().userId) || isAdmin();
      allow create: if isSignedIn() && isValidPredict(incoming())
                     && belongsToOwnCampaign(incoming().campaignId);
      allow update: if false; 
      allow delete: if isOwner(existing().userId) || isAdmin();
    }

    // FIB
    match /fib/{fibId} {
      function isValidFIB(data) {
        return (data.userId == request.auth.uid || isAdmin())
            && (data.campaignId is string || data.campaignId == null)
            && (data.results is map || data.results is string)
            && data.createdAt is timestamp;
      }

      allow read: if isOwner(existing().userId) || isAdmin();
      allow create: if isSignedIn() && isValidFIB(incoming())
                     && belongsToOwnCampaign(incoming().campaignId);
      allow update: if false; 
      allow delete: if isOwner(existing().userId) || isAdmin();
    }
  }
}
