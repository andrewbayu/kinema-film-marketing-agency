rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------
    // Global Deny
    // -------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------
    // Primitives
    // -------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // -------------------------------------------------------------
    // Entities
    // -------------------------------------------------------------

    // Campaigns
    match /campaigns/{campaignId} {
      function isValidCampaign(data) {
        return data.userId == request.auth.uid 
            && data.title is string && data.title.size() <= 200
            && data.createdAt is timestamp;
      }

      allow read: if isOwner(existing().userId);
      allow create: if isSignedIn() && isValidId(campaignId) && isValidCampaign(incoming()) 
                     && incoming().createdAt == request.time;
      allow update: if isOwner(existing().userId) && isValidCampaign(incoming())
                     && incoming().userId == existing().userId
                     && incoming().createdAt == existing().createdAt;
      allow delete: if isOwner(existing().userId);
    }

    // Audience DNA
    match /audience_dna/{dnaId} {
      function isValidDNA(data) {
        return data.userId == request.auth.uid
            && data.campaignId is string
            && data.results is map
            && data.createdAt is timestamp;
      }

      function belongsToOwnCampaign(campaignId) {
        return get(/databases/$(database)/documents/campaigns/$(campaignId)).data.userId == request.auth.uid;
      }

      allow read: if isOwner(existing().userId);
      allow create: if isSignedIn() && isValidId(dnaId) && isValidDNA(incoming())
                     && belongsToOwnCampaign(incoming().campaignId)
                     && incoming().createdAt == request.time;
      allow update: if false; // DNA results should be immutable snapshots
      allow delete: if isOwner(existing().userId);
    }

    // Box Predict
    match /box_predict/{predictId} {
      function isValidPredict(data) {
        return data.userId == request.auth.uid
            && data.campaignId is string
            && data.results is map
            && data.createdAt is timestamp;
      }

      function belongsToOwnCampaign(campaignId) {
        return get(/databases/$(database)/documents/campaigns/$(campaignId)).data.userId == request.auth.uid;
      }

      allow read: if isOwner(existing().userId);
      allow create: if isSignedIn() && isValidId(predictId) && isValidPredict(incoming())
                     && belongsToOwnCampaign(incoming().campaignId)
                     && incoming().createdAt == request.time;
      allow update: if false; // Immutable snapshots
      allow delete: if isOwner(existing().userId);
    }

    // FIB
    match /fib/{fibId} {
      function isValidFIB(data) {
        return data.userId == request.auth.uid
            && data.campaignId is string
            && data.results is map
            && data.createdAt is timestamp;
      }

      function belongsToOwnCampaign(campaignId) {
        return get(/databases/$(database)/documents/campaigns/$(campaignId)).data.userId == request.auth.uid;
      }

      allow read: if isOwner(existing().userId);
      allow create: if isSignedIn() && isValidId(fibId) && isValidFIB(incoming())
                     && belongsToOwnCampaign(incoming().campaignId)
                     && incoming().createdAt == request.time;
      allow update: if false; // Immutable snapshots
      allow delete: if isOwner(existing().userId);
    }
  }
}
