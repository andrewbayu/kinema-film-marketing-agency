rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------
    // Global Deny
    // -------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------
    // Primitives & Helpers
    // -------------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email_verified == true && (
          request.auth.token.email == 'andrew.bayu23@gmail.com' || 
          exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
          exists(/databases/$(database)/documents/team/$(request.auth.token.email))
        )
      );
    }

    function isCampaignOwner(campaignId) {
      return isAdmin() || (
        isSignedIn() && 
        exists(/databases/$(database)/documents/campaigns/$(campaignId)) &&
        get(/databases/$(database)/documents/campaigns/$(campaignId)).data.userId == request.auth.uid
      );
    }

    // -------------------------------------------------------------
    // Validation Blueprints
    // -------------------------------------------------------------
    
    function isValidCampaign(data) {
      return (data.userId == request.auth.uid || isAdmin())
          && data.title is string && data.title.size() <= 200
          && data.createdAt is timestamp
          && (data.lastVisibilityScan == null || data.lastVisibilityScan is timestamp)
          && (data.releaseDate == null || (data.releaseDate is string && data.releaseDate.size() <= 64));
    }

    function isValidVisibility(data) {
      return (data.userId == request.auth.uid || isAdmin())
          && data.campaignId is string
          && data.visibilityScore >= 0 && data.visibilityScore <= 100
          && data.metrics is map
          && data.sentiment is map
          && data.createdAt is timestamp;
    }

    // -------------------------------------------------------------
    // Match Blocks
    // -------------------------------------------------------------
    
    match /team/{email} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /clients/{clientId} {
      allow read: if isSignedIn() && (resource.data.email == request.auth.token.email || isAdmin());
      allow write: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn() && (request.auth.uid == adminId || isAdmin());
      allow write: if isAdmin();
    }

    match /campaigns/{campaignId} {
      allow read: if isOwner(existing().userId) || isAdmin();
      allow create: if isSignedIn() && isValidCampaign(incoming()) && incoming().createdAt == request.time;
      allow update: if (isOwner(existing().userId) || isAdmin()) && (
        // Action: Generic Profile Update
        (isValidCampaign(incoming()) && 
         incoming().userId == existing().userId && 
         incoming().createdAt == existing().createdAt &&
         incoming().diff(existing()).affectedKeys().hasOnly(['title', 'genre', 'budgetTier', 'releaseWindow', 'releaseDate', 'logline', 'leadCast', 'ipType', 'director', 'status'])) ||
        // Action: Update Scan Timestamp (Allowed for system)
        (incoming().diff(existing()).affectedKeys().hasOnly(['lastVisibilityScan']) && incoming().lastVisibilityScan == request.time)
      );
      allow delete: if isOwner(existing().userId) || isAdmin();
    }

    match /visibility_tracker/{scanId} {
      allow read: if isOwner(existing().userId) || isAdmin();
      allow create: if isSignedIn() && isValidVisibility(incoming())
                     && isCampaignOwner(incoming().campaignId)
                     && incoming().createdAt == request.time;
      allow update: if false; 
      allow delete: if isOwner(existing().userId) || isAdmin();
    }

    match /audience_dna/{dnaId} {
      allow read: if isOwner(existing().userId) || isAdmin();
      allow create: if isSignedIn() && isCampaignOwner(incoming().campaignId);
      allow delete: if isOwner(existing().userId) || isAdmin();
    }

    match /box_predict/{predictId} {
      allow read: if isOwner(existing().userId) || isAdmin();
      allow create: if isSignedIn() && isCampaignOwner(incoming().campaignId);
      allow delete: if isOwner(existing().userId) || isAdmin();
    }

    match /fib/{fibId} {
      allow read: if isOwner(existing().userId) || isAdmin();
      allow create: if isSignedIn() && isCampaignOwner(incoming().campaignId);
      allow delete: if isOwner(existing().userId) || isAdmin();
    }

    match /cineforge/{forgeId} {
      allow read: if isOwner(existing().userId) || isAdmin();
      allow create: if isSignedIn() && isCampaignOwner(incoming().campaignId);
      allow delete: if isOwner(existing().userId) || isAdmin();
    }
  }
}
